# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...但保留 .env.local.example 之类的模板文件，仅忽略真实 secrets
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# source assets (already copied into public/)
/icon
/image
/fonts
/high.mp4
/cursorrules
.env*.local

# local sqlite + blob 存储（本地运行态产物，不入库）
/data

# public/fonts/ 下字体文件本机维护，不入库（几百 MB 二进制，git 不适合）
# whitelist 保护历史 tracked 的 22 个字体，防止 git rm --cached 后被误删；
# 新人需要补字体请看 public/fonts/README.md
public/fonts/**/*.ttf
public/fonts/**/*.TTF
public/fonts/**/*.otf
public/fonts/**/*.OTF
public/fonts/**/*.woff
public/fonts/**/*.woff2
!public/fonts/FZLTCHJW.TTF
!public/fonts/FZLTCXHJW.TTF
!public/fonts/FZLTDHJW.TTF
!public/fonts/FZLTHJW.TTF
!public/fonts/FZLTTHJW.TTF
!public/fonts/FZLTXHJW.TTF
!public/fonts/FZLTXIHJW.TTF
!public/fonts/FZLTZCHJW.TTF
!public/fonts/FZLTZHJW.TTF
!public/fonts/FZLTZHUNHJW.TTF
!public/fonts/FZLanTYJW.TTF
!public/fonts/FZLanTYJW_Cu.TTF
!public/fonts/FZLanTYJW_Zhong.TTF
!public/fonts/Meituan Type-Bold.TTF
!public/fonts/Meituan Type-Regular.TTF
!public/fonts/MiSans-Demibold.otf
!public/fonts/MiSans-Medium.otf
